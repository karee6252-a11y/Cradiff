# ---------------------------------------------------------------------------
# Cardiff International School — environment variables
#
# Copy this file to `.env.local` for local development, and add the same
# variables in your Vercel Project Settings → Environment Variables for
# production. NEVER commit real secrets — `.env.local` is git-ignored.
# ---------------------------------------------------------------------------

# SMTP credentials used by the Contact and Careers forms to send email.
# Example below is for Gmail (enable 2FA, then create an "App Password").
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-sender-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Cardiff International School <your-sender-email@gmail.com>"
